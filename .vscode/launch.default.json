{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build and Flash app",
            "executable": "./build/zephyr/zephyr.elf",
            "request": "launch",
            "type": "cortex-debug",
            "device": "nRF52840_xxAA",
            "runToEntryPoint": "main",
            "servertype": "jlink",
            // "gdbPath": "${env:ZEPHYR_SDK_PATH}/gnu/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb",
            "svdFile": "${workspaceFolder}/../modules/hal/nordic/nrfx/bsp/stable/mdk/nrf52840.svd",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            },
            "rtos": "Zephyr",
        }
    ]
}